{
  "name": "fps-airsoft-trajectory-v3",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "description": "F.A.T. — calculateur balistique airsoft fondé sur ATP",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:browser:lot1": "node tests/run-browser-lot1.mjs",
    "test:browser:lot2": "node tests/run-browser-lot2.mjs",
    "test:browser:cockpit": "node tests/run-browser-cockpit-2d.mjs",
    "test:browser:drone": "node tests/run-browser-drone-3d.mjs",
    "test:browser:advanced": "node tests/run-browser-advanced-3d.mjs",
    "test:browser:tutorial": "node tests/run-browser-tutorial.mjs",
    "test:browser:community": "node tests/run-browser-community.mjs",
    "test:browser:radar": "node tests/run-browser-radar.mjs",
    "test:api": "node tests/api.integration.mjs",
    "test:radar-api": "node tests/radar-api.integration.mjs",
    "test:background-removal": "python tests/test_background_removal.py",
    "lighthouse:mobile": "lhci autorun --config=./lighthouserc-mobile.cjs",
    "lighthouse:desktop": "lhci autorun --config=./lighthouserc-desktop.cjs",
    "serve": "php -S 127.0.0.1:8080 bin/local-router.php",
    "db:migrate": "php bin/migrate.php",
    "db:reset:local": "php bin/reset-local-database.php --yes",
    "db:admin:local": "php bin/create-local-test-admin.php",
    "maintenance": "php bin/maintenance.php",
    "sitemap": "node bin/build-sitemap.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "leaflet": "1.9.4",
    "leaflet.markercluster": "1.5.3"
  },
  "devDependencies": {
    "playwright": "1.61.1"
  }
}
