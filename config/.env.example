# Exemple uniquement. En production, le fichier réel reste hors de httpdocs.
APP_ENV=local
APP_ORIGIN=http://127.0.0.1:8081
APP_KEY=replace-with-64-random-hex-characters
DB_DSN=mysql:host=127.0.0.1;port=3307;dbname=fat_test;charset=utf8mb4
DB_USER=fat_test
DB_PASSWORD=replace-with-a-local-test-password
STORAGE_ROOT=storage
MAIL_FROM=noreply@fps-airsoft-trajectory.com
MAIL_MODE=log
SESSION_COOKIE=fat_session
SESSION_TTL_SECONDS=1209600
DELETE_GRACE_DAYS=14
FEATURE_COMMUNITY=false
TRUSTED_HOST=127.0.0.1:8081
REMBG_PYTHON=python
REMBG_WORKER=server/background-removal/worker.py
REMBG_MODEL_HOME=/absolute/private/path/models
REMBG_THREADS=1
REMBG_TIMEOUT_SECONDS=150
OWNER_IMAGE_QUOTA_BYTES=10485760
